/* app.wxss - 全局样式 */

/* CSS 变量 - 主题色 */
page {
  /* 浅色主题 */
  --primary-color: #4A90D9;
  --primary-light: #6BA3E0;
  --primary-dark: #3A7BC8;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-muted: #999999;
  --border-color: #e0e0e0;
  --success-color: #52c41a;
  --warning-color: #faad14;
  --danger-color: #ff4d4f;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
  --shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.12);
}

/* 深色主题 */
page.dark-theme {
  --primary-color: #6BA3E0;
  --primary-light: #8AB8F0;
  --primary-dark: #4A90D9;
  --bg-color: #1a1a1a;
  --card-bg: #2d2d2d;
  --text-primary: #ffffff;
  --text-secondary: #cccccc;
  --text-muted: #888888;
  --border-color: #404040;
  --shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  --shadow-hover: 0 4px 12px rgba(0, 0, 0, 0.4);
}

/* 基础样式 */
page {
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

view, text, image {
  box-sizing: border-box;
}

/* 通用类 */
.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

.card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
}

.card:active {
  box-shadow: var(--shadow-hover);
  transform: translateY(-2rpx);
}

.btn-primary {
  background-color: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary:active {
  background-color: var(--primary-dark);
}

.btn-secondary {
  background-color: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: 8rpx;
  padding: 14rpx 30rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-center {
  text-align: center;
}

.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 进度条样式 */
.progress-container {
  width: 100%;
  height: 12rpx;
  background-color: var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-muted);
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 海报图片 */
.poster {
  width: 100%;
  height: auto;
  border-radius: 12rpx;
  background-color: var(--border-color);
}

/* 评分标签 */
.rating-badge {
  display: inline-flex;
  align-items: center;
  background-color: #ff9500;
  color: #ffffff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 600;
}

/* 状态标签 */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-watching {
  background-color: rgba(74, 144, 217, 0.1);
  color: var(--primary-color);
}

.status-completed {
  background-color: rgba(82, 196, 26, 0.1);
  color: var(--success-color);
}

.status-dropped {
  background-color: rgba(255, 77, 79, 0.1);
  color: var(--danger-color);
}
