/* pages/detail/detail.wxss - 详情页样式 */

.detail-content {
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  padding: 0;
  overflow: hidden;
}

.poster {
  width: 100%;
  height: 500rpx;
  background-color: var(--border-color);
}

.info {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 8rpx;
}

.original-title {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 12rpx;
}

.rating {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.score {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff9500;
  margin-right: 12rpx;
}

.count {
  font-size: 24rpx;
  color: var(--text-muted);
}

.meta {
  display: flex;
  flex-wrap: wrap;
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.meta text {
  margin-right: 20rpx;
}

.genres {
  display: flex;
  flex-wrap: wrap;
}

.genre-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background-color: var(--bg-color);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* 演职员 */
.credits {
  margin-top: 20rpx;
}

.credit-item {
  display: flex;
  margin-bottom: 16rpx;
}

.credit-label {
  font-size: 26rpx;
  color: var(--text-muted);
  width: 100rpx;
  flex-shrink: 0;
}

.credit-value {
  font-size: 26rpx;
  color: var(--text-primary);
  flex: 1;
}

/* 进度区域 */
.progress-section {
  margin-top: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

.status-tabs {
  display: flex;
  margin-bottom: 30rpx;
  background-color: var(--bg-color);
  border-radius: 8rpx;
  padding: 6rpx;
}

.status-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 6rpx;
  transition: all 0.3s ease;
}

.status-tab.active {
  background-color: var(--card-bg);
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: var(--shadow);
}

.progress-controls {
  margin-bottom: 30rpx;
}

.control-group {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.control-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.selector {
  display: flex;
  align-items: center;
}

.selector-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background-color: var(--bg-color);
  color: var(--primary-color);
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  line-height: 1;
}

.selector-btn:active {
  background-color: var(--primary-color);
  color: #ffffff;
}

.selector-value {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin: 0 24rpx;
  min-width: 160rpx;
  text-align: center;
}

.progress-bar-container {
  width: 100%;
  height: 16rpx;
  background-color: var(--border-color);
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
  margin-bottom: 24rpx;
}

.action-buttons {
  margin-top: 20rpx;
}

.btn-block {
  width: 100%;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 统计区域 */
.stats-section {
  margin-top: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 简介 */
.summary-section {
  margin-top: 20rpx;
}

.summary-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: var(--text-secondary);
  transition: all 0.3s ease;
}

.summary-text.collapsed {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 4;
  overflow: hidden;
}

.expand-hint {
  display: block;
  text-align: center;
  font-size: 26rpx;
  color: var(--primary-color);
  margin-top: 16rpx;
  padding: 12rpx;
}

/* 删除区域 */
.delete-section {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn-danger {
  width: 100%;
  background-color: var(--danger-color);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-danger:active {
  opacity: 0.8;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 120rpx;
  color: var(--text-muted);
}
