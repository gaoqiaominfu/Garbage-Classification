/* pages/search/search.wxss - 搜索页样式 */

/* 搜索框 */
.search-box {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background-color: var(--card-bg);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow);
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  margin-right: 16rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.clear-icon {
  font-size: 28rpx;
  color: var(--text-muted);
  padding: 8rpx;
}

.search-btn {
  background-color: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.search-btn:active {
  background-color: var(--primary-dark);
}

/* API 源指示器 */
.api-indicator {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 10rpx 20rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
}

.api-text {
  color: var(--text-muted);
  margin-right: 8rpx;
}

.api-badge {
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.api-badge.auto {
  background-color: #1890ff;
  color: #ffffff;
}

.api-badge.tmdb {
  background-color: #000000;
  color: #ffffff;
}

.api-badge.douban {
  background-color: #00b51d;
  color: #ffffff;
}

.api-badge.douban-cloud {
  background-color: #07c160;
  color: #ffffff;
}

.cloud-badge {
  margin-left: 8rpx;
  padding: 4rpx 8rpx;
  background-color: #f0f0f0;
  border-radius: 6rpx;
  font-size: 20rpx;
  color: #666;
}

/* 热门搜索 */
.hot-search {
  padding: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-secondary);
  margin-bottom: 20rpx;
}

.hot-tags {
  display: flex;
  flex-wrap: wrap;
}

.hot-tag {
  background-color: var(--card-bg);
  color: var(--text-secondary);
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  box-shadow: var(--shadow);
}

.hot-tag:active {
  background-color: var(--primary-color);
  color: #ffffff;
}

/* 搜索结果 */
.result-list {
  padding: 0 20rpx;
}

.result-count {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 20rpx;
}

.result-item {
  display: flex;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.result-poster {
  width: 120rpx;
  height: 170rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: var(--border-color);
}

.result-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 8rpx 0;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.result-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
}

.result-rating {
  color: #ff9500;
  font-weight: 600;
  margin-left: 16rpx;
}

.result-genres {
  display: flex;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.result-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background-color: var(--bg-color);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.add-hint {
  font-size: 22rpx;
  color: var(--primary-color);
  margin-top: 8rpx;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
  color: var(--text-muted);
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
}
