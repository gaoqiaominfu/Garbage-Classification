/* pages/index/index.wxss - 首页样式 */

/* 统计栏 */
.stats-bar {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 搜索入口 */
.search-entry {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #ffffff;
}

.search-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.search-text {
  font-size: 30rpx;
  font-weight: 500;
}

/* 追剧列表 */
.drama-list {
  margin-top: 20rpx;
}

/* 影视卡片 */
.drama-card {
  padding: 0;
  overflow: hidden;
}

.card-header {
  display: flex;
  padding: 24rpx;
}

.card-poster {
  width: 160rpx;
  height: 220rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background-color: var(--border-color);
}

.card-info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 4rpx 0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.card-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
}

.card-year {
  margin-right: 16rpx;
}

.card-rating {
  color: #ff9500;
  font-weight: 600;
}

.card-genres {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.genre-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background-color: var(--bg-color);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

/* 进度区域 */
.card-progress {
  padding: 0 24rpx 24rpx;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.progress-text {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
}

.progress-percent {
  font-size: 24rpx;
  color: var(--primary-color);
  font-weight: 600;
}

/* 操作区域 */
.card-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 24rpx 24rpx;
  border-top: 1rpx solid var(--border-color);
  margin: 0 24rpx;
  padding-top: 24rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.btn-add-episode {
  background-color: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: 6rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

.btn-add-episode:active {
  background-color: var(--primary-dark);
}

.btn-mark {
  background-color: var(--success-color);
  color: #ffffff;
  border: none;
  border-radius: 6rpx;
  padding: 8rpx 20rpx;
  font-size: 24rpx;
}

.btn-mark:active {
  opacity: 0.8;
}

/* 更新时间 */
.card-update-time {
  padding: 16rpx 24rpx;
  background-color: var(--bg-color);
  text-align: right;
}

.card-update-time text {
  font-size: 22rpx;
  color: var(--text-muted);
}

/* 空状态 */
.empty-state {
  padding: 160rpx 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-top: 20rpx;
  display: block;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  display: block;
}
